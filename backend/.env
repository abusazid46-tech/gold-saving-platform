# Application
APP_NAME="Gold Saving Platform"
APP_VERSION="1.0.0"
DEBUG=True
SECRET_KEY="change-this-secret-key-in-production-please-use-a-strong-key"
API_V1_PREFIX="/api/v1"

# Database (you'll update this later)
DATABASE_URL="postgresql://postgres:password@localhost:5432/gold_saving_db"
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis
REDIS_URL="redis://localhost:6379/0"

# JWT
JWT_SECRET_KEY="your-jwt-secret-key-change-this"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OTP
OTP_EXPIRE_MINUTES=5
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Razorpay (you'll get these from razorpay.com)
RAZORPAY_KEY_ID="rzp_test_xxx"
RAZORPAY_KEY_SECRET="xxx"
RAZORPAY_WEBHOOK_SECRET="xxx"

# Gold Price API
GOLD_PRICE_API_URL="https://api.mcx.com/v1/gold"
GOLD_PRICE_API_KEY=""

# AWS S3
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET_NAME="gold-saving-kyc"
AWS_REGION="ap-south-1"

# Admin
ADMIN_EMAIL="admin@goldsaving.com"
ADMIN_PASSWORD_HASH=""
